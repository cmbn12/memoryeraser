"UnlitGeneric"
{
    "$basetexture" "memory_eraser/brain_slide"
    "$translucent" 1
    "$vertexcolor" 1
    "$vertexalpha" 1
    
    "Proxies"
    {
        "AnimatedTexture"
        {
            "animatedtexturevar" "$basetexture"
            "animatedtextureframenumvar" "$frame"
            "animatedtextureframerate" 15 
        }
    }
}